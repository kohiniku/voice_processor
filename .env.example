# ASR backend: whisper or qwen
ASR_BACKEND=whisper

# Whisper backend
WHISPER_MODEL=large

# Qwen backend
QWEN_MODEL=Qwen/Qwen3-ASR-0.6B
QWEN_LOAD_BACKEND=transformers
QWEN_DEVICE_MAP=auto
QWEN_DTYPE=bfloat16
QWEN_MAX_NEW_TOKENS=256
QWEN_MAX_INFERENCE_BATCH_SIZE=1

# Default language hint
DEFAULT_LANGUAGE=ja
